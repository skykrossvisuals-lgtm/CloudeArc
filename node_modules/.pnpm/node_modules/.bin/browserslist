else
  export NODE_PATH="/home/aurelix-systems/Downloads/CloudeArc-7zip-1zip/node_modules/.pnpm/browserslist@4.28.2/node_modules/browserslist/node_modules:/home/aurelix-systems/Downloads/CloudeArc-7zip-1zip/node_modules/.pnpm/browserslist@4.28.2/node_modules:/home/aurelix-systems/Downloads/CloudeArc-7zip-1zip/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../browserslist/cli.js" "$@"
else
  exec node  "$basedir/../browserslist/cli.js" "$@"
fi
